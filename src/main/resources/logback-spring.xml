<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Load config from application properties -->
    <springProperty name="LOGS" source="application.log.path" defaultValue="./logs" />
    <springProperty name="PORT" source="server.port" />

    <!-- Console appender with colored output -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>%white(%d{ISO8601}) %highlight(%-5level) [%blue(%t)] [%magenta(${PORT})] %yellow(%C{1}:%L): %msg%n%throwable</Pattern>
        </layout>
    </appender>

    <!-- File appender with daily rotation and 250MB size limit -->
    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <Pattern>%d %p [%t] [${PORT}] %C{1}:%L %m%n</Pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOGS}/%d{yyyy-MM, aux}/%d{yyyy-MM-dd}/loan-management-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>250MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- Root logger - logs to both file and console -->
    <root level="info">
        <appender-ref ref="RollingFile" />
        <appender-ref ref="Console" />
    </root>
</configuration>